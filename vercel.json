{
  "builds": [
    {
      "src": "api/app.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "api/templates/**" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/app.py" }
  ],
  "crons": [
    {
      "path": "/api/cron-scrape?limit=15",
      "schedule": "*/15 * * * *"
    }
  ]
}
